@model Tasneem_Shop.Entities.Models.Category
@{
    ViewData["Title"] = "Create Category";
}
@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
<div class="container mt-4">
    <h2>Create New Category</h2>
    <hr />
    <form asp-action="Create" method="post">    
        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" placeholder="Enter category name..." />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label"></label>
            <input asp-for="Description" class="form-control" placeholder="Enter description..." /> 
            <span asp-validation-for="Description" class="text-danger"></span>

        </div>

        <div class="mb-3">
            <button type="submit" class="btn btn-primary">Create</button>
            <a asp-action="Index" asp-controller="Category" class="btn btn-warning">Back</a>
        </div>
    </form>
</div>