@model IEnumerable<Tasneem_Shop.Entities.Models.Category>


 <link rel="stylesheet" href="~/css/category.css" />


 <a asp-action="Create" asp-controller="Category" class="btn btn-outline-primary">create Category</a>
<table class="custom-table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Description</th>
            <th>Created Time</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Description</td>
                <td>@item.CreatedTime.ToString("yyyy-MM-dd")</td>
                <td>
                    <a asp-action="Edit" asp-controller="Category" asp-route-id="@item.Id" class="btn btn-primary">Edit</a>
                    <a asp-action="Delete" asp-controller="Category" asp-route-id="@item.Id" class="btn btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>